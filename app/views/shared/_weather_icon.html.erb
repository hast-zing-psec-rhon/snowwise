<% icon_name = local_assigns.fetch(:icon, "cloudy") %>
<% icon_size = local_assigns.fetch(:size, "small") %>

<span class="weather-art weather-art-<%= icon_size %> weather-art-<%= icon_name %>" aria-hidden="true">
  <svg viewBox="0 0 96 96" role="img" focusable="false">
    <% if icon_name == "clear" %>
      <circle class="weather-sun" cx="48" cy="48" r="18" />
      <g class="weather-rays">
        <line x1="48" y1="12" x2="48" y2="22" />
        <line x1="48" y1="74" x2="48" y2="84" />
        <line x1="12" y1="48" x2="22" y2="48" />
        <line x1="74" y1="48" x2="84" y2="48" />
        <line x1="23" y1="23" x2="30" y2="30" />
        <line x1="66" y1="66" x2="73" y2="73" />
        <line x1="23" y1="73" x2="30" y2="66" />
        <line x1="66" y1="30" x2="73" y2="23" />
      </g>
    <% elsif icon_name == "partly_cloudy" %>
      <circle class="weather-sun" cx="36" cy="34" r="16" />
      <g class="weather-rays weather-rays-soft">
        <line x1="36" y1="8" x2="36" y2="17" />
        <line x1="14" y1="34" x2="23" y2="34" />
        <line x1="49" y1="21" x2="56" y2="14" />
        <line x1="19" y1="17" x2="25" y2="23" />
      </g>
      <path class="weather-cloud-shadow" d="M29 67h38c9 0 16-6 16-14s-7-14-16-14h-1c-4-10-13-16-24-16-13 0-23 9-25 21-7 1-13 6-13 13 0 6 6 10 25 10z" />
      <path class="weather-cloud" d="M29 63h38c9 0 16-6 16-14s-7-14-16-14h-1c-4-10-13-16-24-16-13 0-23 9-25 21-7 1-13 6-13 13 0 6 6 10 25 10z" />
    <% else %>
      <path class="weather-cloud-shadow" d="M25 66h43c10 0 18-7 18-16s-8-16-18-16h-2c-4-11-15-19-27-19-15 0-27 11-29 25-8 1-15 7-15 15 0 7 7 11 30 11z" />
      <path class="weather-cloud" d="M25 62h43c10 0 18-7 18-16s-8-16-18-16h-2c-4-11-15-19-27-19-15 0-27 11-29 25-8 1-15 7-15 15 0 7 7 11 30 11z" />

      <% if icon_name == "rain" %>
        <g class="weather-rain">
          <line x1="32" y1="70" x2="26" y2="82" />
          <line x1="48" y1="70" x2="42" y2="84" />
          <line x1="64" y1="70" x2="58" y2="82" />
        </g>
      <% elsif icon_name == "snow" %>
        <g class="weather-snow">
          <path d="M30 72v16M22 80h16M24 74l12 12M36 74L24 86" />
          <path d="M50 68v18M41 77h18M43 70l14 14M57 70L43 84" />
          <path d="M70 72v16M62 80h16M64 74l12 12M76 74L64 86" />
        </g>
      <% end %>
    <% end %>
  </svg>
</span>
