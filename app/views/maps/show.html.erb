<% content_for(:title, "Map | Snowwise") %>
<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIINfQad5dLwE0EvQbTfo2f6vffkHJ2h8dY=" crossorigin="">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<% end %>

<div class="ski-page-shell" data-controller="resort-map" data-resort-map-resorts-value="<%= resort_map_json(@map_resorts) %>">
  <nav class="site-nav" aria-label="Primary navigation">
    <%= link_to(root_path, class: "brand-mark") do %>
      <span class="brand-icon">❄</span>
      <span>Snowwise</span>
<% end %>

<div class="nav-links">
  <%= link_to("Conditions", root_path) %>
  <%= link_to("Map", map_path, class: "active") %>
</div>

  </nav>

  <header class="hero-panel map-page-hero">
    <div>
      <h1>Map</h1>
      <p>Find ski resorts by location, pass access, and snow quality.</p>
    </div>

    <%= link_to("View Conditions", root_path, class: "map-button") %>
  </header>

  <main class="map-page-content">
    <section class="map-shell">
      <aside class="map-sidebar">
        <section class="map-panel map-filters" aria-labelledby="map-filter-heading">
          <div class="map-panel__header">
            <p class="eyebrow">Explore</p>
            <h2 id="map-filter-heading">Filter resorts</h2>
          </div>

          <label class="filter-field">
            <span>Pass type</span>
            <select data-resort-map-target="passFilter" data-action="change->resort-map#applyFilters">
              <option value="all">All passes</option>
              <option value="Ikon">Ikon</option>
              <option value="Epic">Epic</option>
              <option value="No Pass">No Pass</option>
            </select>
          </label>

          <label class="filter-field">
            <span>Region</span>
            <select data-resort-map-target="regionFilter" data-action="change->resort-map#applyFilters">
              <option value="all">All regions</option>
              <% @map_regions.each do |region| %>
                <option value="<%= region %>"><%= region %></option>
              <% end %>
            </select>
          </label>

          <label class="filter-field">
            <span>Minimum snow base depth</span>
            <select data-resort-map-target="depthFilter" data-action="change->resort-map#applyFilters">
              <option value="0">Any depth</option>
              <option value="12">1 foot+</option>
              <option value="24">2 feet+</option>
              <option value="48">4 feet+</option>
              <option value="72">6 feet+</option>
              <option value="96">8 feet+</option>
            </select>
          </label>

          <label class="filter-field">
            <span>7-day snow forecast</span>
            <select data-resort-map-target="snowFilter" data-action="change->resort-map#applyFilters">
              <option value="0">Any forecast</option>
              <option value="3">3+ in</option>
              <option value="6">6+ in</option>
              <option value="12">12+ in</option>
              <option value="18">18+ in</option>
            </select>
          </label>


          <label class="filter-toggle">
            <input type="checkbox" data-resort-map-target="openFilter" data-action="change->resort-map#applyFilters">
            <span>Confirmed open only</span>
          </label>

          <fieldset class="label-mode">
            <legend>Marker labels</legend>
            <label><input type="radio" name="marker-label-mode" value="conditions_score" checked data-action="change->resort-map#changeLabelMode"> Score</label>
            <label><input type="radio" name="marker-label-mode" value="current_temperature" data-action="change->resort-map#changeLabelMode"> Temp</label>
            <label><input type="radio" name="marker-label-mode" value="seven_day_snowfall_total" data-action="change->resort-map#changeLabelMode"> 7-day snow forecast</label>
          </fieldset>

          <button type="button" class="secondary-button" data-action="click->resort-map#clearFilters">Clear filters</button>
        </section>

        <section class="map-panel map-insights" aria-live="polite" aria-labelledby="map-insights-heading">
          <div class="map-panel__header">
            <p class="eyebrow">Live view</p>
            <h2 id="map-insights-heading">Best in view</h2>
          </div>

          <div class="insight-grid" data-resort-map-target="insights">
            <article class="insight-card"><span>Matching resorts</span><strong data-insight="count"><%= @map_summary[:resort_count] %></strong></article>
            <article class="insight-card"><span>Best conditions</span><strong data-insight="best"><%= map_summary_name(@map_summary, :best_conditions) %></strong></article>
            <article class="insight-card"><span>Most 7-day snow forecast</span><strong data-insight="snow"><%= map_summary_name(@map_summary, :most_forecast_snow) %></strong></article>
            <article class="insight-card"><span>Best Ikon</span><strong data-insight="ikon"><%= map_summary_name(@map_summary, :best_ikon) %></strong></article>
            <article class="insight-card"><span>Best Epic</span><strong data-insight="epic"><%= map_summary_name(@map_summary, :best_epic) %></strong></article>
          </div>
        </section>
      </aside>

      <section class="map-stage" aria-label="Interactive ski resort map">
        <div class="map-toolbar">
          <strong data-resort-map-target="resultCount"><%= pluralize(@map_resorts.size, "resort") %> shown</strong>
          <span>OpenStreetMap tiles</span>
        </div>
        <div class="resort-map" data-resort-map-target="map" role="application" aria-label="Interactive ski resort map"></div>
        <p class="map-empty-state" data-resort-map-target="emptyState" hidden>No resorts match these filters. Try clearing one or more filters.</p>
      </section>

      <aside class="selected-resort-card" data-resort-map-target="selectedCard" aria-live="polite">
        <div class="selected-resort-card__empty">
          <p class="eyebrow">Selected resort</p>
          <h2>Pick a marker</h2>
          <p>Click or tap a resort marker to compare pass access, snowpack, current weather, and 7-day snow forecast.</p>
        </div>
      </aside>
    </section>
  </main>
</div>
